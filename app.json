{
  "expo": {
    "name": "Bull4X",
    "slug": "bull4x",
    "version": "1.0.3",
    "runtimeVersion": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/bull4x-app-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-bull4x.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "splash": {
        "image": "./assets/splash-bull4x.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      },
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      },
      "bundleIdentifier": "com.bull4x.app"
    },
    "android": {
      "usesCleartextTraffic": true,
      "splash": {
        "image": "./assets/splash-bull4x.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/bull4x-app-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.bull4x.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "shivam92388",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-bull4x.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      "expo-updates"
    ]
  }
}
