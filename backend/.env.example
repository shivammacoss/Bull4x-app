# Copy to .env and fill in. No remote API host is hardcoded in code.

PORT=5000
# Listen on all interfaces so Android emulator (10.0.2.2) and LAN devices can reach the API.
HOST=0.0.0.0
MONGODB_URI=

# URLs your backend uses for OxaPay webhooks, email links, and defaults when DB settings are empty.
PUBLIC_API_URL=http://127.0.0.1:5000
PUBLIC_WEB_URL=http://localhost:5173
SUPPORT_EMAIL=support@example.com

# Optional: comma-separated browser origins allowed by CORS (merged with localhost defaults in server.js).
# CORS_ORIGINS=
# CORS_ORIGIN=
